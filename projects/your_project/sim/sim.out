    %store/vec4 v0x556a4ea415f0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x556a4ea418d0_0, 0, 1;
    %delay 148000000, 0;
T_16.0 ;
    %pushi/vec4 1, 0, 32;
    %or/r;
    %flag_set/vec4 8;
    %jmp/0xz T_16.1, 8;
    %delay 100000, 0;
    %vpi_call 3 46 "$display", "Time: %0t ns | Alive...", $time {0 0 0};
    %jmp T_16.0;
T_16.1 ;
    %vpi_call 3 50 "$display", "Dead" {0 0 0};
    %vpi_call 3 51 "$finish" {0 0 0};
    %end;
    .thread T_16;
